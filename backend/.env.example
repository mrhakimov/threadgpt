# Required
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
PORT=8000

# Security (recommended for production)
# 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
# If unset, an ephemeral key is generated — sessions will not survive restart.
TOKEN_ENCRYPTION_KEY=

# Set to the frontend origin in production (e.g. https://yourdomain.com)
# If unset, defaults to http://localhost:3000 with a warning.
ALLOWED_ORIGIN=

# Set to "true" when running behind a trusted reverse proxy that sets X-Real-IP / X-Forwarded-Proto
TRUSTED_PROXY=false

# Set to "true" in production to mark cookies as Secure (HTTPS-only)
COOKIE_SECURE=false

# Maximum number of simultaneous authenticated sessions held in memory (default: 1000)
MAX_TOKEN_STORE_SIZE=1000
